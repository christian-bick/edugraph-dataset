{
  "name": "edugraph-content",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:coverage": "vitest run --coverage && npx vite-node src/scripts/check-generator-coverage.ts",
    "check:labels": "npx vite-node src/scripts/check-labels.ts",
    "check:specs": "npx vite-node src/scripts/validate-specs.ts",
    "check:types": "tsc --noEmit",
    "generate:dataset": "npx vite-node src/scripts/generate-dataset.ts",
    "validate:dataset": "npx vite-node src/scripts/validate-dataset.ts",
    "test:vqa": "npx vite-node src/scripts/validate-dataset.ts",
    "report:coverage": "npx vite-node src/scripts/generate-coverage-report.ts",
    "generate:standards-explorer": "npm run map:standards",
    "map:standards": "npx vite-node src/scripts/map-standards.ts",
    "validate:coverage": "npx vite-node src/scripts/validate-coverage.ts",
    "upload:gcs": "npx vite-node src/scripts/upload-to-gcs.ts",
    "sync:gcs": "npx vite-node src/scripts/upload-to-gcs.ts --sync",
    "sync:gcs:dry": "npx vite-node src/scripts/upload-to-gcs.ts --sync --dry",
    "upload:s3": "npx vite-node src/scripts/upload-to-s3.ts",
    "sync:s3": "npx vite-node src/scripts/upload-to-s3.ts --sync",
    "sync:s3:dry": "npx vite-node src/scripts/upload-to-s3.ts --sync --dry"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.525.0",
    "@google-cloud/storage": "^7.16.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.7",
    "cross-env": "^10.0.0",
    "dotenv": "^17.2.1",
    "glob": "^11.0.3",
    "playwright": "^1.60.0",
    "puppeteer": "^24.16.0",
    "sass-embedded": "^1.90.0",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.0",
    "vite-node": "^3.2.4",
    "vite-plugin-handlebars": "^2.0.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "edugraph-ts": "https://github.com/christian-bick/edugraph-ontology/releases/download/v0.9.2/edugraph-ts.tgz",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
